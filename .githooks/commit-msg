#!/bin/sh
msg=$(cat "$1")
pattern='^(feat|fix|chore|docs|style|refactor|test|ci|build|perf|revert)(\(.+\))?(!)?: .+'
if ! echo "$msg" | grep -qE "$pattern"; then
  echo "Commit message must follow Conventional Commits: type(scope): description"
  echo "Types: feat fix chore docs style refactor test ci build perf revert"
  exit 1
fi
